---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Page Not Found | PTD Inc."
  description="The page you were looking for doesn't exist. Return to PTD Inc. tree service homepage."
  canonicalPath="/404"
>
  <section class="not-found grain-overlay">
    <div class="container not-found-content">
      <p class="label not-found-label">Error 404</p>
      <h1 class="display-hero not-found-heading">
        That Page<br />
        <span class="text-amber">Got Cut.</span>
      </h1>
      <p class="body-lg text-linen-dim not-found-body">
        Looks like this page was removed or never existed. Head back and find what you need.
      </p>
      <div class="not-found-actions">
        <a href="/" class="btn btn--primary" id="not-found-home">Back to Home</a>
        <a href="/contact" class="btn btn--outline" id="not-found-contact">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, var(--color-bark) 0%, var(--color-charcoal) 70%);
    position: relative;
    overflow: hidden;
  }

  .not-found::before {
    content: '404';
    position: absolute;
    font-family: var(--font-display);
    font-size: clamp(12rem, 30vw, 28rem);
    color: rgba(160, 98, 42, 0.06);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    pointer-events: none;
    line-height: 1;
    user-select: none;
  }

  .not-found-content {
    position: relative;
    z-index: 2;
    padding-top: 100px;
    padding-bottom: 80px;
  }

  .not-found-label { margin-bottom: 1.5rem; display: block; }
  .not-found-heading { margin-bottom: 1.5rem; }
  .not-found-body { max-width: 440px; margin-bottom: 2.5rem; }

  .not-found-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>
