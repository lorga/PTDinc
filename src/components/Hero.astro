---
// Hero.astro — Homepage hero
---
<section class="hero grain-overlay" id="hero" aria-label="PTD Inc. tree service hero">
  <!-- Background image -->
  <div class="hero-bg">
    <img
      src="/images/hero-bg.webp"
      alt="PTD Inc. crew removing a large oak tree in Springfield, NJ"
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
      class="hero-img"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-text">
      <p class="label hero-eyebrow">Licensed Tree Service — Union County, NJ</p>
      <h1 class="display-hero hero-heading">
        We Cut.<br />
        <span class="text-amber">You Stay</span><br />
        Safe.
      </h1>
      <p class="body-lg hero-body text-linen-dim">
        Tree removal and pruning done right the first time. PTD Inc. has been clearing properties across New Jersey for over 20 years. No subcontractors. No shortcuts.
      </p>
      <div class="hero-actions">
        <a href="tel:+15555555555" class="btn btn--primary" id="hero-cta-call">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call for a Free Quote
        </a>
        <a href="/services/tree-removal" class="btn btn--outline" id="hero-cta-services">
          Our Services
        </a>
      </div>

      <!-- Trust bar -->
      <div class="hero-trust">
        <div class="trust-item">
          <span class="trust-num">20+</span>
          <span class="trust-desc body-sm text-linen-dim">Years in Service</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-num">2,400+</span>
          <span class="trust-desc body-sm text-linen-dim">Trees Removed</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-num">100%</span>
          <span class="trust-desc body-sm text-linen-dim">Insured & Licensed</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Diagonal bottom cut -->
  <div class="hero-cut" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <polygon points="0,80 1440,0 1440,80" fill="#1A1F1B"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(26, 31, 27, 0.92) 0%,
      rgba(26, 31, 27, 0.75) 50%,
      rgba(26, 31, 27, 0.35) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: 100px;
    padding-bottom: 100px;
  }

  .hero-text {
    max-width: 640px;
  }

  .hero-eyebrow {
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.7s 0.2s var(--ease-out-expo) forwards;
  }

  .hero-heading {
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.7s 0.35s var(--ease-out-expo) forwards;
  }

  .hero-body {
    max-width: 520px;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fadeUp 0.7s 0.5s var(--ease-out-expo) forwards;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
    opacity: 0;
    animation: fadeUp 0.7s 0.65s var(--ease-out-expo) forwards;
  }

  /* Trust bar */
  .hero-trust {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.7s 0.8s var(--ease-out-expo) forwards;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .trust-num {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-amber);
    line-height: 1;
  }

  .trust-divider {
    width: 1px;
    height: 40px;
    background: rgba(244, 239, 230, 0.2);
    flex-shrink: 0;
  }

  /* Bottom diagonal */
  .hero-cut {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    height: 80px;
    pointer-events: none;
  }

  .hero-cut svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
