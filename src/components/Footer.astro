---
// Footer.astro
const year = new Date().getFullYear();
---
<footer class="site-footer" id="site-footer">
  <div class="footer-top">
    <div class="container footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo-link" aria-label="PTD Inc. — Home">
          <span class="footer-logo-name">PTD Inc.</span>
        </a>
        <p class="footer-tagline body-sm text-linen-dim">
          Tree removal and pruning you can count on. Licensed, insured, and operating in Union County, NJ since 2005.
        </p>
        <p class="footer-license label">NJ License &num; TRC-00549821</p>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h3 class="footer-col-heading label">Services</h3>
        <ul class="footer-links">
          <li><a href="/services/tree-removal" class="footer-link link-amber">Tree Removal</a></li>
          <li><a href="/services/tree-trimming" class="footer-link link-amber">Tree Trimming</a></li>
          <li><a href="/services/tree-trimming" class="footer-link link-amber">Crown Pruning</a></li>
          <li><a href="/services/tree-removal" class="footer-link link-amber">Stump Grinding</a></li>
          <li><a href="/services/tree-removal" class="footer-link link-amber">Emergency Removal</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div class="footer-col">
        <h3 class="footer-col-heading label">Company</h3>
        <ul class="footer-links">
          <li><a href="/about" class="footer-link link-amber">About PTD Inc.</a></li>
          <li><a href="/contact" class="footer-link link-amber">Contact Us</a></li>
          <li><a href="/contact" class="footer-link link-amber">Free Estimate</a></li>
        </ul>
      </div>

      <!-- NAP / Contact -->
      <div class="footer-col footer-nap">
        <h3 class="footer-col-heading label">Contact</h3>
        <address class="footer-address">
          <p>123 Timber Lane</p>
          <p>Springfield, NJ 07081</p>
        </address>
        <a href="tel:+15555555555" class="footer-phone" id="footer-cta-call">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (555) 555-5555
        </a>
        <a href="mailto:info@ptdinc.com" class="footer-email link-amber">info@ptdinc.com</a>
        <p class="footer-hours body-sm text-linen-dim">Mon–Sat &nbsp;7:00am – 6:00pm</p>
      </div>
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="body-sm text-linen-dim">
        &copy; {year} PTD Inc. All rights reserved. &nbsp;&bull;&nbsp; Springfield, NJ
      </p>
      <div class="footer-trust">
        <span class="trust-badge" title="Better Business Bureau Accredited">BBB Accredited</span>
        <span class="trust-badge" title="Fully Insured">Fully Insured</span>
        <span class="trust-badge" title="Licensed by State of NJ">NJ Licensed</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bark);
    border-top: 2px solid var(--color-amber);
    margin-top: 0;
  }

  .footer-top {
    padding-block: var(--space-16);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
      gap: var(--space-12);
    }
  }

  /* Brand */
  .footer-logo-link {
    display: inline-block;
    margin-bottom: var(--space-4);
    text-decoration: none;
  }

  .footer-logo-name {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-linen);
    letter-spacing: 0.08em;
  }

  .footer-tagline {
    margin-bottom: var(--space-4);
    max-width: 300px;
  }

  .footer-license {
    margin-top: var(--space-3);
    color: var(--color-amber);
    font-size: 0.7rem;
  }

  /* Columns */
  .footer-col-heading {
    margin-bottom: var(--space-4);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-link {
    font-size: 0.9rem;
    color: var(--color-linen-dim);
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-amber);
  }

  /* NAP */
  .footer-nap {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-address {
    font-style: normal;
    font-size: 0.9rem;
    color: var(--color-linen-dim);
    line-height: 1.7;
  }

  .footer-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--color-amber);
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .footer-phone:hover {
    color: var(--color-amber-lt);
  }

  .footer-email {
    font-size: 0.875rem;
    color: var(--color-linen-dim);
  }

  .footer-hours {
    margin-top: var(--space-1);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(244, 239, 230, 0.08);
    padding-block: var(--space-6);
  }

  .footer-bottom-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .footer-bottom-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .footer-trust {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .trust-badge {
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-moss-lt);
    border: 1px solid var(--color-moss);
    padding: 0.2rem 0.6rem;
  }
</style>
